#    VITE_WMS_API_BASE="https://wms.yourdomain.com/api"
# 3. Local development:
#    VITE_WMS_API_BASE="http://localhost:3001/api"
VITE_WMS_API_BASE="https://ubdhljxyleqsixrewtto.supabase.co/functions/v1"

# IMPORTANT: Make sure the WMS API server allows CORS from this origin:
